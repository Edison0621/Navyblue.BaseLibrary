{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": ""
  },
  "Navyblue": {
    "WorkerId": 1,
    "DataCenterId": 1,
    "Redis": {
      "ConnectionString": "",
      "InstanceName": "navyblue"
    },
    "Cache": {
      "Prefix": "webapi",
      "DefaultExpiration": "00:20:00"
    }
  },
  "Jwt": {
    "Issuer": "Navyblue",
    "Audience": "NavyblueWebApi.Api",
    "SigningKey": "",
    "Expire": "00:30:00",
    "RequireHttpsMetadata": true
  },
  "RefreshToken": {
    "Expire": "7.00:00:00"
  }
}
